{
  "name": "inpainting_3d_spade",
  "finetune_norm": false,
  "model": {
    "which_model": {
      "name": ["models.model", "Palette"],
      "args": {
        "sample_num": 8,
        "task": "inpainting",
        "optimizers": [
          { "lr": 5e-5, "weight_decay": 0}
        ]
      }
    },
    "which_networks": [
      {
        "name": ["models.network", "Network"],
        "args": {
          "unet": {
            "image_size": 96,
            "in_channel": 3,
            "inner_channel": 32,
            "out_channel": 1,
            "res_blocks": 2,
            "attn_res": [16],
            "channel_mults": [1, 2, 4, 8],
            "dropout": 0,
            "use_checkpoint": false,
            "use_fp16": false,
            "num_heads": 1,
            "num_head_channels": -1,
            "use_scale_shift_norm": false,
            "resblock_updown": true,
            "use_new_attention_order": false,
            "spade_seg_channel": 1
          },
          "beta_schedule": {
            "train": {
              "schedule": "linear",
              "n_timestep": 1000,
              "linear_start": 1e-6,
              "linear_end": 1e-2
            },
            "val": {
              "schedule": "linear",
              "n_timestep": 1000,
              "linear_start": 1e-6,
              "linear_end": 1e-2
            },
            "test": {
              "schedule": "linear",
              "n_timestep": 1000,
              "linear_start": 1e-6,
              "linear_end": 1e-2
            }
          },
          "module_name": "spade_diffusion_3d"
        }
      }
    ],
    "which_losses": [
      {
        "name": ["models.loss", "l1_loss"]
      }
    ],
    "which_metrics": [
      {
        "name": ["models.metric", "mae"]
      }
    ]
  },
